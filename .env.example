# ============================================
# BRVM Agent - Variables d'environnement
# ============================================

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
MODEL_ENRICHMENT=claude-sonnet-4-6
MODEL_SYNTHESIS=claude-opus-4-7

# --- PostgreSQL (Railway injecte DATABASE_URL automatiquement) ---
DATABASE_URL=postgresql://user:password@host:5432/brvm_agent

# --- Brevo Email (SMTP) — identité expéditeur + credentials ---
# Les DESTINATAIRES sont gérés en DB (table `recipients`) via POST /api/recipients
# EMAIL_TO ci-dessous = seed-only : crée 1 recipient au 1er boot si la table est vide
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-login@smtp-brevo.com
BREVO_SMTP_PASSWORD=xxxxx
EMAIL_FROM=brvm-agent@tondomaine.ci
EMAIL_FROM_NAME=BRVM Agent
EMAIL_TO=toi@tondomaine.ci

# --- Wassoya WhatsApp (https://wassoya.com/docs) ---
# Wassoya impose l'envoi via template Meta approuvé — à créer côté Wassoya AVANT.
WASSOYA_API_KEY=
WASSOYA_API_BASE_URL=https://api.wassoya.com
WASSOYA_SENDER_NUMBER=2250700000000
WASSOYA_TEMPLATE_NAME=brvm_brief_v1
# Seed-only : crée 1 recipient WhatsApp au 1er boot si la table est vide (format E.164)
WHATSAPP_TO_NUMBER=+2250700000000

# --- Scheduler ---
TIMEZONE=Africa/Abidjan
DEFAULT_CRON=0 8 * * *

# --- Profil investisseur (prompt Opus) ---
INVESTOR_PROFILE=Long terme (3-5 ans) orienté dividendes et value. Secteurs préférés : bancaire, télécoms, industrie. Éviter titres illiquides (volume < 500/jour). Tolérance risque modérée.

# --- Admin API (OBLIGATOIRE) ---
# Génère un token aléatoire (min. 24 caractères) :
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_TOKEN=

# --- Observabilité (optionnel mais recommandé) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Logs ---
LOG_LEVEL=INFO
